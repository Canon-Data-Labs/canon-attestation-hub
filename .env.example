# Stellar / Soroban
STELLAR_NETWORK=testnet                          # testnet | mainnet
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
ATTESTATION_CONTRACT_ID=                         # deployed contract address
SOROBAN_SOURCE_PUBLIC_KEY=                       # funded public key used for read simulations

# Backend
PORT=3001
PROVER_BIN=/usr/local/bin/canon-prover           # container path (mounted via docker-compose volume)
MANIFEST_DIR=/data/manifests                     # allowed directory for dataset manifest files

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001
